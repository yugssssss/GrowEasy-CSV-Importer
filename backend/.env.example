# ---- Required ----
# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ---- Optional (sensible defaults shown) ----
# Model used for extraction. gpt-4o-mini is cheap and accurate for this task.
OPENAI_MODEL=gpt-4o-mini

# Server port
PORT=5000

# How many CSV rows go to the model per request
BATCH_SIZE=15
# How many batches run in parallel
BATCH_CONCURRENCY=3
# Retries per failed batch (exponential backoff)
MAX_RETRIES=3

# Safety limits
MAX_ROWS=5000
MAX_FILE_SIZE_MB=5

# CORS: set to your deployed frontend URL in production, e.g.
# CORS_ORIGIN=https://your-frontend.vercel.app
# Use * to allow all origins (fine for local dev).
CORS_ORIGIN=*
